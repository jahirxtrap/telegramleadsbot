# Env vars for staging/prod (Render dashboard).
# Local dev reads these from a .env file at the project root (auto-loaded by core/config.py).

# Public base URL of this service (used to register the Telegram webhook)
BACKEND_URL=http://localhost:8000

# Telegram — token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Any random string. Telegram echoes it back in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=change-me-openssl-rand-hex-32

# Google Sheets — deployed Apps Script web app URL (ends in /exec)
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/AKfyc.../exec
# Shared secret checked inside the Apps Script doPost
SHEETS_SHARED_SECRET=change-me-openssl-rand-hex-32

# Cerebras — API key from https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-8b
